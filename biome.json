{
	"$schema": "https://biomejs.dev/schemas/2.4.13/schema.json",
	"linter": {
		"enabled": true,
		"rules": {
			"recommended": true,
			"style": {
				"noNonNullAssertion": "off",
				"useConst": "error",
				"useNodejsImportProtocol": "off"
			},
			"suspicious": {
				"noExplicitAny": "off",
				"noControlCharactersInRegex": "off",
				"noEmptyInterface": "off"
			}
		}
	},
	"formatter": {
		"enabled": true,
		"formatWithErrors": false,
		"indentStyle": "tab",
		"indentWidth": 3,
		"lineWidth": 120
	},
	"files": {
		"includes": [
			"src/**/*.ts",
			"tests/**/*.ts",
			"vitest.config.ts",
			"package.json",
			"tsconfig.json",
			"biome.json",
			"!**/node_modules/**/*",
			"!!**/node_modules"
		]
	}
}
