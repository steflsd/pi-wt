{
	"name": "@steflsd/pi-wt",
	"version": "0.0.1",
	"private": true,
	"type": "module",
	"packageManager": "pnpm@10.33.2+sha512.a90faf6feeab71ad6c6e57f94e0fe1a12f5dcc22cd754db40ae9593eb6a3e0b6b12e3540218bb37ae083404b1f2ce6db2a4121e979829b4aff94b99f49da1cf8",
	"description": "Worktree switcher extension for Pi Coding Agent",
	"repository": {
		"type": "git",
		"url": "git+ssh://git@github.com/steflsd/pi-wt.git"
	},
	"homepage": "https://github.com/steflsd/pi-wt#readme",
	"license": "MIT",
	"bugs": {
		"url": "https://github.com/steflsd/pi-wt/issues"
	},
	"keywords": [
		"pi-package",
		"pi",
		"worktree"
	],
	"files": [
		"src",
		"prompts",
		"README.md"
	],
	"engines": {
		"node": ">=20.6.0"
	},
	"pi": {
		"extensions": [
			"./src/index.ts"
		]
	},
	"peerDependencies": {
		"@mariozechner/pi-ai": "^0.70.0",
		"@mariozechner/pi-coding-agent": "^0.70.0",
		"@mariozechner/pi-tui": "^0.70.0"
	},
	"devDependencies": {
		"@biomejs/biome": "2.4.13",
		"@mariozechner/pi-ai": "^0.70.0",
		"@mariozechner/pi-coding-agent": "^0.70.0",
		"@mariozechner/pi-tui": "^0.70.0",
		"@types/node": "^25.6.0",
		"typescript": "^6.0.3",
		"vitest": "^4.1.5"
	},
	"scripts": {
		"format": "biome check --write .",
		"lint": "biome check --error-on-warnings .",
		"typecheck": "tsc --noEmit",
		"test": "vitest run",
		"test:watch": "vitest",
		"check": "biome check --write --error-on-warnings . && pnpm run typecheck && pnpm run test",
		"update": "pnpm up -i -L",
		"prepublishOnly": "pnpm run check"
	}
}
