{
	"name": "@steflsd/pi-wt",
	"version": "0.0.1",
	"private": true,
	"type": "module",
	"packageManager": "pnpm@10.33.0",
	"description": "Worktree switcher extension for Pi Coding Agent",
	"repository": {
		"type": "git",
		"url": "git+ssh://git@github.com/steflsd/pi-wt.git"
	},
	"homepage": "https://github.com/steflsd/pi-wt#readme",
	"license": "MIT",
	"bugs": {
		"url": "https://github.com/steflsd/pi-wt/issues"
	},
	"keywords": [
		"pi-package",
		"pi",
		"worktree"
	],
	"files": [
		"src",
		"README.md"
	],
	"engines": {
		"node": ">=20.6.0"
	},
	"pi": {
		"extensions": [
			"./src/index.ts"
		]
	},
	"peerDependencies": {
		"@mariozechner/pi-coding-agent": "*"
	},
	"devDependencies": {
		"@biomejs/biome": "2.3.5",
		"@mariozechner/pi-coding-agent": "*",
		"@types/node": "^24.0.0",
		"typescript": "^5.9.0"
	},
	"scripts": {
		"format": "biome check --write .",
		"lint": "biome check --error-on-warnings .",
		"typecheck": "tsc --noEmit",
		"check": "biome check --write --error-on-warnings . && pnpm run typecheck",
		"update": "pnpm up -i -L",
		"prepublishOnly": "pnpm run check"
	}
}
